#include "stm32f10x.h"
#include "key.h"
#include "keyint.h"
#include "led.h"
#include "delay.h"
#include "beep.h"
#include "uart.h"
#include "tim6.h"
#include "tim3.h"
#include "adc.h"
#include "lcd1602.h"
#include "string.h"
#include "oled_iic.h"
#include "ds18b20.h"
#include "motor.h"
#include "dht11_driver.h"
#include "stdio.h"


/* --------------------------------------------------------- */
/* 模式定义 */
/* --------------------------------------------------------- */
typedef enum
{
    MODE_REMOTE = 0, // 远程模式
    MODE_AUTO = 1,   // 自动模式
    MODE_MANUL = 2   // 手动模式
}   ModeType;

/* 【新增/修复】定义全局模式变量和执行机构状态变量 */
ModeType CurrentMode = MODE_AUTO; // 初始化为自动模式

// 【修复 Bug】删除 DCColor，使用 Fan_Status 跟踪风扇状态
uint8_t Fan_Status = 0;           // DC 直流电机/风扇状态 (0:关, 1:开)

// 新增变量：步进电机计时器，单位：秒
uint8_t StepMotor_Timer = 0; 
// 新增变量：步进电机动作状态 (0:停止, 1:正转开启中, 2:反转关闭中)
uint8_t StepMotor_Action = 0; 
// 新增变量：排风口位置状态 (0:关闭, 1:开启)
uint8_t Vent_Position = 0; 
// 新增变量：窗帘状态 (0:关闭, 1:打开)
uint8_t curtain_Status = 0; 

/* 外部变量引用声明 */
extern uint8_t strBuff[32];                 // 串口接收缓冲区
extern uint8_t rxFlag;                      // 串口接收标志位
extern volatile uint16_t ADC_ConvertedValue[2]; // DMA搬运的ADC值 [0]:光照 [1]:烟雾
extern uint8_t timeFlag500ms;               // 0.5s定时标志位
extern uint8_t timeFlag5s;                  // 5s定时标志位
extern uint8_t  keyFlag;                    // DK1按键中断标志位

uint8_t keyValue;
// 传感器数据
float lightpercent = 0.0;
float MQ2_ConvertedValue = 0;
short temp;
float temperature = 0.0; 
DHT11_Data_TypeDef humi_temp;
ErrorStatus dhtStatus = ERROR; 

// 显示缓冲区
char Lcd_Line1[17] = "Mode: AUTO      "; // LCD行1
char Lcd_Line2[17] = "System Normal   "; // LCD行2


/*********************************************************************
 @Function  : DC风扇控制 (ON/OFF) - 对应 motor.c 中的 PA4 引脚
 @Parameter : status : 1: ON, 0: OFF
**********************************************************************/
void Set_DC_Motor(uint8_t status)
{
    if (status)
    {
        // 假设 PA4 控制 DC 电机
        GPIO_SetBits(GPIOA, GPIO_Pin_4); 
        Fan_Status = 1; // 更新状态变量
    }
    else
    {
        GPIO_ResetBits(GPIOA, GPIO_Pin_4); 
        Fan_Status = 0; // 更新状态变量
    }
}

/*********************************************************************
 @Function  : 步进电机计时与停止 (10s)
 @Note      : 解决了电机运行10s后停止，但排风口状态应保持的问题。
**********************************************************************/
void StepMotor_Timer_Run(void)
{
    // 只在电机正在执行开启(1)或关闭(2)动作时才计时
    if (StepMotor_Action != 0) 
    {
        StepMotor_Timer++; // 运行计数器加1
        
        if (StepMotor_Timer >= 10) // 达到 10 秒（完成动作）
        {
            StepMotorControl(0);     // 停止电机
            
            // 根据动作状态更新排风口位置，然后重置动作状态
            if(StepMotor_Action == 1) // 开启动作完成
            {
                Vent_Position = 1; // 排风口设置为开启
                printf("Vent Step Motor: OPEN action complete. Vent Status: OPEN\r\n");
            }
            else if (StepMotor_Action == 2) // 关闭动作完成
            {
                Vent_Position = 0; // 排风口设置为关闭
                printf("Vent Step Motor: CLOSE action complete. Vent Status: CLOSE\r\n");
            }
            
            StepMotor_Action = 0;    // 动作状态清零（停止）
            StepMotor_Timer = 0;     // 计时器清零
        }
    }
}

int main(void)
{
    // ---------------------------------------------------------
    // 1. 硬件外设初始化
    // ---------------------------------------------------------
    delay_init();           
    LedInit();              
    BeepInit();             
    UART1_Config();         
    TIM6_Config();          
    TIM3_PWM_Init();        
    ADC1_Init();            
    Lcd1602Init();          
    OLED_Init();            
    OLED_Clear();           
    DS18B20_Init();         
    DHT11_GPIO_Config();    
    KeyInit();              // 【修复】添加按键轮询初始化 (DK2/3/4 需要)
    KeyIntConfig();         // DK1 使用中断
    // ... (初始化屏幕显示) ...
    
    // 设置中断优先级分组
    NVIC_PriorityGroupConfig(NVIC_PriorityGroup_0);
    
    
    while(1)
    {
        
        // -----------------------------------------------------
        // 2. 传感器数据采集与计算
        // -----------------------------------------------------
        
        // A. 心跳灯
        if(timeFlag500ms == 1)  
        {
            GPIOA->ODR ^= GPIO_Pin_7; 
            timeFlag500ms = 0;        
        }
        
        // B. 光照计算
        lightpercent = (float)ADC_ConvertedValue[0] / 4095.0 * 100.0;
        
        // C. 烟雾计算 (MQ2)
        MQ2_ConvertedValue = 100.0 * (float)ADC_ConvertedValue[1] / 4095.0; 
        
        // D. 温度采集 (DS18B20, 每5秒更新一次值)
        if(timeFlag5s) 
        {
            temp = DS18B20_Get_Temp();
            if(temp < 0) temperature = (float)(-temp * 0.1);
            else temperature = (float)(temp * 0.1);
            timeFlag5s = 0; 
        }
				
		// E. 读取DHT11温湿度
        dhtStatus = Read_DHT11(&humi_temp);
		
		// -----------------------------------------------------
        // 3. 模式切换逻辑 (DK1 中断处理)
        // -----------------------------------------------------
        if (keyFlag == 1) 
        {
            delay_ms(20); 
            if (GPIO_ReadInputDataBit(GPIOC,GPIO_Pin_4)==0) 
            {
                // 切换模式：REMOTE (0) -> AUTO (1) -> MANUL (2) -> REMOTE (0)
                CurrentMode = (ModeType)((CurrentMode + 1) % 3); 
                
                // 模式切换后，关闭所有执行机构 (确保安全和状态清零)
                Set_DC_Motor(0); // 关闭 DC 风扇
                
                // 如果步进电机正在动作，强制停止
                if(StepMotor_Action != 0) 
                {
                    StepMotorControl(0);
                    StepMotor_Action = 0;
                    StepMotor_Timer = 0;
                }
                curtain_Status = 0; 
            }
            keyFlag = 0; // 清除标志位
        }
        
        // -----------------------------------------------------
        // 4. 工作模式控制逻辑
        // -----------------------------------------------------
        switch((int)CurrentMode)
		{
			case MODE_REMOTE: // 远程控制模式
                
                sprintf((char*)Lcd_Line1, "Mode: REMOTE    ");
                sprintf((char*)Lcd_Line2, "Wait for Cmd    ");
                
                if(rxFlag == 1)
                {
                    if (strstr((char*)strBuff, "FAN_ON")) Set_DC_Motor(1);
                    else if (strstr((char*)strBuff, "FAN_OFF")) Set_DC_Motor(0);
                    // 远程控制步进电机 (直接触发动作)
                    else if (strstr((char*)strBuff, "VENT_OPEN")) 
                    {
                        if (Vent_Position == 0 && StepMotor_Action == 0) // 仅当关闭且未动作时触发开启
                        {
                            StepMotorControl(1); 
                            StepMotor_Action = 1; 
                            StepMotor_Timer = 0;
                            printf("Remote: Vent OPEN command received.\r\n");
                        }
                    }
                    else if (strstr((char*)strBuff, "VENT_CLOSE")) 
                    {
                        if (Vent_Position == 1 && StepMotor_Action == 0) // 仅当开启且未动作时触发关闭
                        {
                            StepMotorControl(2); 
                            StepMotor_Action = 2; 
                            StepMotor_Timer = 0;
                            printf("Remote: Vent CLOSE command received.\r\n");
                        }
                    }
                    
                    rxFlag = 0; 
                    memset(strBuff, 0, 32);
                }
                
                break;
       
            case MODE_AUTO: // 自动控制模式 
                
                // A. DC风扇控制 (温度 > 35C OR 甲烷 > 50%)
                if (temperature > 35.0 || MQ2_ConvertedValue > 50.0)
                {
                    Set_DC_Motor(1); // 开启 DC 风扇 
                }
                else if (temperature < 32.0 && MQ2_ConvertedValue < 45.0) // 增加回差
                {
                    Set_DC_Motor(0); // 关闭 DC 风扇
                }

                // B. 步进电机/排风口控制 (CH4 > 50%)
                if (MQ2_ConvertedValue > 50.0) 
                {
                    if (Vent_Position == 0 && StepMotor_Action == 0) // 仅当排风口关闭且未动作时才开启
                    {
                        StepMotorControl(1); // 正转开启
                        StepMotor_Action = 1; 
                        StepMotor_Timer = 0;
                        printf("Auto: High Gas. Vent OPEN triggered.\r\n");
                    }
                }
                else if (MQ2_ConvertedValue < 45.0) // 增加回差
                {
                    if (Vent_Position == 1 && StepMotor_Action == 0) // 仅当排风口开启且未动作时才关闭
                    {
                        StepMotorControl(2); // 反转关闭
                        StepMotor_Action = 2; 
                        StepMotor_Timer = 0;
                        printf("Auto: Gas Normal. Vent CLOSE triggered.\r\n");
                    }
                }
                
                // C. 窗帘控制 (光照 < 30%)
                if(lightpercent < 30 && curtain_Status == 0) 
                {
                    curtain_Status = 1;        
                }
                else if(lightpercent > 60 && curtain_Status == 1) 
                {
                    curtain_Status = 0;        
                }
                
                sprintf((char*)Lcd_Line1, "Mode: AUTO      ");
                sprintf((char*)Lcd_Line2, "FAN:%s VENT:%s", Fan_Status ? "ON " : "OFF", Vent_Position ? "OPEN" : "CLSD");

                break;
			
            case MODE_MANUL: // 手动控制模式
                
                sprintf((char*)Lcd_Line1, "Mode: MANUL     ");
                
                // 读取按键 (KEY2, KEY3, KEY4)
                keyValue = KeyScan();
                
                if(keyValue == KEY2) // DK2 (PC5) - 控制风扇开关
                {
                    Set_DC_Motor(!Fan_Status); // 翻转 DC 风扇的状态
                    delay_ms(50); 
                }
                else if(keyValue == KEY3) // DK3 (PC6) - 步进电机正转 (开启排风口)
                {
                    if (Vent_Position == 0 && StepMotor_Action == 0) // 确保排风口是关闭的且电机未在动作
                    {
                        StepMotorControl(1); // 正转开启
                        StepMotor_Action = 1; 
                        StepMotor_Timer = 0;
                        printf("Manual: Vent OPEN command received.\r\n");
                    }
                }
                else if(keyValue == KEY4) // DK4 (PC7) - 步进电机反转 (关闭排风口)
                {
                    if (Vent_Position == 1 && StepMotor_Action == 0) // 确保排风口是开启的且电机未在动作
                    {
                        StepMotorControl(2); // 反转关闭
                        StepMotor_Action = 2; 
                        StepMotor_Timer = 0;
                        printf("Manual: Vent CLOSE command received.\r\n");
                    }
                }
                
                // LCD第二行显示执行机构状态
                sprintf((char*)Lcd_Line2, "FAN:%s VENT:%s", Fan_Status ? "ON " : "OFF", Vent_Position ? "OPEN" : "CLSD");
                
                break;
        }
				
        // -----------------------------------------------------
        // 5. 显示更新 
        // -----------------------------------------------------
        
        // 刷新 LCD
        Lcd1602ShowString(1, 0, (uint8_t*)Lcd_Line1, 16); // 第一行显示模式
        Lcd1602ShowString(2, 0, (uint8_t*)Lcd_Line2, 16); // 第二行显示状态

        // 刷新 OLED
        sprintf((char*)strBuff, "Light:%.1f%%   ", lightpercent);
        OLED_ShowCH(0, 0, (uint8_t*)strBuff); 
        
        sprintf((char*)strBuff, "CH4  :%.1f%%   ", MQ2_ConvertedValue);
        OLED_ShowCH(0, 2, (uint8_t*)strBuff);
        
        sprintf((char*)strBuff,"Temp :%d.%dC  ",humi_temp.temp_int,humi_temp.temp_deci);
        OLED_ShowCH(0, 4, (uint8_t*)strBuff);
        
        if(dhtStatus == SUCCESS)
        {
			sprintf((char*)strBuff,"Humi :%d%%  ",humi_temp.humi_int);
        }
        else
        {
            sprintf((char*)strBuff, "Humi :Error    "); 
        }
        OLED_ShowCH(0, 6, (uint8_t*)strBuff);


        // -----------------------------------------------------
        // 6. 串口统一输出 
        // -----------------------------------------------------
        
        printf("\r\n--- Sensor Status ---\r\n");
        printf("Mode        : %s\r\n", (CurrentMode == MODE_REMOTE) ? "REMOTE" : ((CurrentMode == MODE_AUTO) ? "AUTO" : "MANUAL"));
        printf("P-Motor Act : %s\r\n", (StepMotor_Action == 0) ? "STOP" : ((StepMotor_Action == 1) ? "OPENING" : "CLOSING"));
        printf("Vent Status : %s\r\n", Vent_Position ? "OPEN" : "CLOSE");
        printf("Fan Status  : %s\r\n", Fan_Status ? "ON" : "OFF"); 
        printf("Light Level : %.1f %%\r\n", lightpercent);
        printf("Smoke Level : %.1f %%\r\n", MQ2_ConvertedValue);
        printf("Temperature : %.1f C\r\n", temperature);
        if(dhtStatus == SUCCESS)
        {
            printf("Humidity    : %d %%\r\n", humi_temp.humi_int);
        }
        else
        {
            printf("Humidity    : Read Error\r\n");
        }
        printf("Curtain     : %s\r\n", curtain_Status ? "OPEN" : "CLOSE");


        // -----------------------------------------------------
        // 7. 定时与延时
        // -----------------------------------------------------
        StepMotor_Timer_Run(); // 检查步进电机是否运行满10秒
        
        delay_ms(1000); 
    } 
}